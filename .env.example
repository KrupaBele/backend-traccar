PORT=4010
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/backend-vehicle

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Where to send alert messages
ALERT_WHATSAPP_TO=whatsapp:+91xxxxxxxxxx

# Cooldown in seconds to avoid duplicate spam
ALERT_COOLDOWN_SECONDS=300

# Traccar upstream for autonomous server-side polling
TRACCAR_BASE_URL=http://127.0.0.1:8082/api
TRACCAR_USERNAME=admin
TRACCAR_PASSWORD=admin
TRACCAR_POLLING_SECONDS=15
